    "db:stop": "pnpx supabase stop",
    "db:push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:reset": "pnpx supabase db reset",
    "db:status": "pnpx supabase status",
    "db:seed": "pnpx tsx --env-file=.env src/server/drizzle/seed/index.ts",
    "pp:recalculate": "dotenv -e .env -- pnpx tsx src/server/drizzle/scripts/recalculate-all-pp.ts",
    "prepare": "husky"
  },
